{
  "name": "@nullseal/n8c",
  "version": "0.3.0",
  "description": "Terraform-style, code-first CLI to version and deploy n8n workflows, prompts and credentials from a database.",
  "type": "module",
  "license": "MIT",
  "author": "ltmin",
  "keywords": [
    "n8n",
    "cli",
    "gitops",
    "infrastructure-as-code",
    "workflow",
    "automation",
    "terraform",
    "mongodb",
    "sqlite"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "bin": {
    "n8c": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nullseal/n8c"
  },
  "homepage": "https://github.com/nullseal/n8c#readme",
  "bugs": {
    "url": "https://github.com/nullseal/n8c/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test",
    "start": "node src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "tsc -p tsconfig.build.json",
    "prepublishOnly": "node --test && npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "mongodb": "^6.8.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3"
  }
}
